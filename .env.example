# Khamsat Monitor - Environment Variables
# Copy to .env and fill in values

# Poll interval in milliseconds (default: 300000 = 5 min)
# POLL_INTERVAL_MS=300000

# Server port (default: 3000)
# PORT=3000

# Khamsat session cookies for authenticated requests
# Required for: posting comments, and optional for richer feed/profile data
# Copy the rack.session value from your browser (DevTools → Application → Cookies → khamsat.com)
#
# Option A - Full Cookie header string:
# KHAMSAT_COOKIES="rack.session=YOUR_VALUE; khamsat_cart=...; rb=%2F"
#
# Option B - Just the rack.session value (we prepend "rack.session=" automatically):
# KHAMSAT_COOKIES="YOUR_RACK_SESSION_VALUE_HERE"
